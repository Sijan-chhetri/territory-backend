generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, uuid_ossp(map: "uuid-ossp", schema: "public")]
}

enum AuthProvider {
  EMAIL
  GOOGLE
  APPLE
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  username String  @unique
  password String?
  fullName String? @map("full_name")
  country  String?
  city     String?

  weight Float?

  authProvider AuthProvider @default(EMAIL) @map("auth_provider")
  googleId     String?      @unique @map("google_id")
  appleId      String?      @unique @map("apple_id")

  fcmToken String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  receivedFriendRequests  FriendRequest[]        @relation("FriendRequestReceiver")
  sentFriendRequests      FriendRequest[]        @relation("FriendRequestSender")
  friendOf                Friendship[]           @relation("FriendshipFriend")
  friends                 Friendship[]           @relation("FriendshipUser")
  activities              Activity[]
  clanActivities          ClanActivity[]
  clanInvitesSent         ClanInvite[]           @relation("ClanInviteSender")
  clanInvitesReceived     ClanInvite[]           @relation("ClanInviteReceiver")
  clanJoinRequests        ClanJoinRequest[]
  clanMemberships         ClanMember[]
  clanTerritoriesCaptured ClanTerritory[]
  clanCaptain             Clan[]                 @relation("ClanCaptain")
  notifications           Notification[]
  territories             Territory[]
  badges                  UserBadge[]
  progress                UserProgress?
  xpTransactions          XPTransaction[]
  clanMessages            ClanMessage[]
  createdClanEvents       ClanEvent[]            @relation("CreatedClanEvents")
  clanEventParticipants   ClanEventParticipant[]
  createdClubWars         ClubWar[]              @relation("CreatedClubWars")

  @@index([email])
  @@index([username])
  @@index([googleId])
  @@index([appleId])
  @@map("users")
}

model Clan {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  description String?
  logo        String?
  banner      String?
  isPrivate   Boolean @default(false)
  maxMembers  Int     @default(50)

  country  String?
  imageUrl String? @map("image_url")

  /// *
  /// * |--------------------------------------------------------------------------
  /// * | CAPTAIN
  /// * |--------------------------------------------------------------------------
  captainId          String
  /// *
  /// * |--------------------------------------------------------------------------
  /// * | LEADERBOARD STATS
  /// * |--------------------------------------------------------------------------
  totalXp            Float                    @default(0)
  totalDistanceKm    Float                    @default(0)
  totalActivities    Int                      @default(0)
  territoryCount     Int                      @default(0)
  totalAreaKm2       Float                    @default(0)
  wins               Int                      @default(0)
  losses             Int                      @default(0)
  rank               Int?
  weeklyXp           Float                    @default(0)
  monthlyXp          Float                    @default(0)
  weeklyDistanceKm   Float                    @default(0)
  monthlyDistanceKm  Float                    @default(0)
  /// *
  /// * |--------------------------------------------------------------------------
  /// * | TIMESTAMPS
  /// * |--------------------------------------------------------------------------
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  activities         ClanActivity[]
  invites            ClanInvite[]
  joinRequests       ClanJoinRequest[]
  leaderboardHistory ClanLeaderboardHistory[]
  members            ClanMember[]
  territories        ClanTerritory[]
  captain            User                     @relation("ClanCaptain", fields: [captainId], references: [id], onDelete: Cascade)

  messages       ClanMessage[]
  challengerWars ClubWar[]     @relation("ChallengerClanWars")
  opponentWars   ClubWar[]     @relation("OpponentClanWars")
  wonWars        ClubWar[]     @relation("WinnerClanWars")

  warStats ClubWarParticipant[]
  events   ClanEvent[]

  @@index([name])
  @@index([rank])
  @@map("clans")
}

model ClanMember {
  id       String   @id @default(uuid())
  clanId   String
  userId   String
  role     ClanRole @default(RUNNER)
  joinedAt DateTime @default(now())
  clan     Clan     @relation(fields: [clanId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clanId, userId])
  @@index([clanId])
  @@index([userId])
  @@index([role])
  @@map("clan_members")
}

model ClanJoinRequest {
  id        String                @id @default(uuid())
  clanId    String
  userId    String
  status    ClanJoinRequestStatus @default(PENDING)
  message   String?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  clan      Clan                  @relation(fields: [clanId], references: [id], onDelete: Cascade)
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clanId, userId])
  @@index([clanId])
  @@index([userId])
  @@map("clan_join_requests")
}

model ClanInvite {
  id            String           @id @default(uuid())
  clanId        String
  invitedById   String
  invitedUserId String
  status        ClanInviteStatus @default(PENDING)
  message       String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  clan          Clan             @relation(fields: [clanId], references: [id], onDelete: Cascade)
  invitedBy     User             @relation("ClanInviteSender", fields: [invitedById], references: [id], onDelete: Cascade)
  invitedUser   User             @relation("ClanInviteReceiver", fields: [invitedUserId], references: [id], onDelete: Cascade)

  @@unique([clanId, invitedUserId])
  @@index([clanId])
  @@index([invitedById])
  @@index([invitedUserId])
  @@map("clan_invites")
}

model ClanTerritory {
  id               String    @id @default(uuid())
  clanId           String
  territoryId      String
  capturedByUserId String?
  /// *
  /// * |--------------------------------------------------------------------------
  /// * | TERRITORY STATS
  /// * |--------------------------------------------------------------------------
  areaKm2          Float
  capturedAt       DateTime  @default(now())
  capturedBy       User?     @relation(fields: [capturedByUserId], references: [id])
  clan             Clan      @relation(fields: [clanId], references: [id], onDelete: Cascade)
  territory        Territory @relation(fields: [territoryId], references: [id], onDelete: Cascade)

  @@unique([clanId, territoryId])
  @@index([clanId])
  @@index([territoryId])
  @@map("clan_territories")
}

model ClanActivity {
  id                  String    @id @default(uuid())
  clanId              String
  userId              String
  activityId          String?
  /// *
  /// * |--------------------------------------------------------------------------
  /// * | CONTRIBUTION
  /// * |--------------------------------------------------------------------------
  xpEarned            Float     @default(0)
  distanceKm          Float     @default(0)
  territoriesCaptured Int       @default(0)
  areaCapturedKm2     Float     @default(0)
  /// *
  /// * |--------------------------------------------------------------------------
  /// * | TIMESTAMPS
  /// * |--------------------------------------------------------------------------
  createdAt           DateTime  @default(now())
  activity            Activity? @relation(fields: [activityId], references: [id])
  clan                Clan      @relation(fields: [clanId], references: [id], onDelete: Cascade)
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clanId])
  @@index([userId])
  @@map("clan_activities")
}

model ClanLeaderboardHistory {
  id             String   @id @default(uuid())
  clanId         String
  rank           Int
  xp             Float
  distanceKm     Float
  territoryCount Int
  totalAreaKm2   Float
  type           String
  createdAt      DateTime @default(now())
  clan           Clan     @relation(fields: [clanId], references: [id], onDelete: Cascade)

  @@index([clanId])
  @@index([rank])
  @@map("clan_leaderboard_history")
}

model FriendRequest {
  id         String              @id @default(uuid())
  senderId   String
  receiverId String
  status     FriendRequestStatus @default(PENDING)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  receiver   User                @relation("FriendRequestReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User                @relation("FriendRequestSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
}

model Friendship {
  id        String   @id @default(uuid())
  userId    String
  friendId  String
  createdAt DateTime @default(now())
  friend    User     @relation("FriendshipFriend", fields: [friendId], references: [id], onDelete: Cascade)
  user      User     @relation("FriendshipUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId])
  @@index([friendId])
}

model Activity {
  id     String @id @default(uuid())
  /// *
  /// * |--------------------------------------------------------------------------
  /// * | RELATIONS
  /// * |--------------------------------------------------------------------------
  userId String

  clientActivityId String?

  /// *
  /// * |--------------------------------------------------------------------------
  /// * | ACTIVITY DATA
  /// * |--------------------------------------------------------------------------
  mode           ActivityMode
  distanceKm     Float
  durationSec    Int
  stopTime       Int?
  elapsedTime    Int?
  movingTime     Int?
  avgPace        Float
  topPace        Float?
  avgSpeed       Float?
  topSpeed       Float?
  calories       Float
  elevationGain  Float?
  startedAt      DateTime
  endedAt        DateTime
  routeEncoded   String?
  kmSplits       Json?
  routeGeometry  Unsupported("geometry")?
  /// *
  /// * |--------------------------------------------------------------------------
  /// * | TIMESTAMPS
  /// * |--------------------------------------------------------------------------
  createdAt      DateTime                 @default(now())
  includeInClan  Boolean                  @default(false) @map("include_in_clan")
  notes          String?
  user           User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clanActivities ClanActivity[]
  territories    Territory[]
  xptransactions XPTransaction[]

  @@unique([userId, clientActivityId])
  @@index([userId])
  @@map("activities")
}

model Territory {
  id                   String                   @id @default(uuid())
  userId               String
  activityId           String?
  landmassId           String?
  name                 String?
  boundary             Unsupported("geometry")
  center               Unsupported("geometry")?
  routeEncoded         String?
  routeGeometry        Unsupported("geometry")?
  areaKm2              Float
  capturedAt           DateTime                 @default(now())
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  routeSegmentsEncoded Json?
  clanTerritories      ClanTerritory[]
  activity             Activity?                @relation(fields: [activityId], references: [id])
  user                 User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([activityId])
  @@index([landmassId])
  @@map("territories")
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  title       String
  message     String
  type        String
  territoryId String?
  activityId  String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "notifications_user_fk")

  @@index([isRead], map: "notifications_is_read_idx")
  @@index([userId], map: "notifications_user_idx")
  @@map("notifications")
}

model TerritoryEvent {
  id              String                   @id @default(uuid())
  territoryId     String?
  userId          String
  activityId      String?
  opponentUserId  String?
  type            String
  affectedAreaKm2 Float
  geometry        Unsupported("geometry")?
  createdAt       DateTime                 @default(now())

  @@index([userId])
  @@index([opponentUserId])
  @@index([activityId])
  @@map("territory_events")
}

model UserProgress {
  id                  String   @id @default(uuid())
  userId              String   @unique
  /// *
  /// * |--------------------------------------------------------------------------
  /// * | LEVEL SYSTEM
  /// * |--------------------------------------------------------------------------
  level               Int      @default(0)
  currentXp           Int      @default(0)
  totalXp             Int      @default(0)
  xpToNextLevel       Int      @default(50)
  totalDistanceKm     Float    @default(0)
  /// *
  /// * |--------------------------------------------------------------------------
  /// * | STREAKS
  /// * |--------------------------------------------------------------------------
  currentStreak       Int      @default(0)
  longestStreak       Int      @default(0)
  /// *
  /// * |--------------------------------------------------------------------------
  /// * | ACHIEVEMENTS
  /// * |--------------------------------------------------------------------------
  territoriesOwned    Int      @default(0)
  territoriesCaptured Int      @default(0)
  activitiesCount     Int      @default(0)
  /// *
  /// * |--------------------------------------------------------------------------
  /// * | TIMESTAMPS
  /// * |--------------------------------------------------------------------------
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([level])
  @@map("user_progress")
}

model XPTransaction {
  id          String    @id @default(uuid())
  userId      String
  activityId  String?
  amount      Int
  type        String
  description String?
  createdAt   DateTime  @default(now())
  activity    Activity? @relation(fields: [activityId], references: [id])
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@map("xp_transactions")
}

model Badge {
  id               String      @id @default(uuid())
  name             String      @unique
  slug             String      @unique
  description      String
  icon             String?
  xpReward         Int         @default(0)
  rarity           String?
  /// *
  /// * |--------------------------------------------------------------------------
  /// * | CONDITIONS
  /// * |--------------------------------------------------------------------------
  requirementType  String
  requirementValue Int
  createdAt        DateTime    @default(now())
  users            UserBadge[]

  @@map("badges")
}

model UserBadge {
  id       String   @id @default(uuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

model ClanMessage {
  id        String   @id @default(uuid())
  clanId    String
  senderId  String
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clan   Clan @relation(fields: [clanId], references: [id], onDelete: Cascade)
  sender User @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([clanId])
  @@index([senderId])
  @@index([createdAt])
}

model ClubWar {
  id String @id @default(uuid())

  type   ClubWarType
  status ClubWarStatus @default(PENDING)

  seasonName String?
  startsAt   DateTime
  endsAt     DateTime

  challengerClanId String?
  opponentClanId   String?

  challengerClan Clan? @relation("ChallengerClanWars", fields: [challengerClanId], references: [id])
  opponentClan   Clan? @relation("OpponentClanWars", fields: [opponentClanId], references: [id])

  winnerClanId String?
  winnerClan   Clan?   @relation("WinnerClanWars", fields: [winnerClanId], references: [id])

  createdByUserId String?
  createdByUser   User?   @relation("CreatedClubWars", fields: [createdByUserId], references: [id])

  acceptedAt  DateTime?
  declinedAt  DateTime?
  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ClubWarParticipant[]

  @@index([status])
  @@index([type])
  @@index([startsAt, endsAt])
}

model ClubWarParticipant {
  id String @id @default(uuid())

  warId  String
  clanId String

  war  ClubWar @relation(fields: [warId], references: [id], onDelete: Cascade)
  clan Clan    @relation(fields: [clanId], references: [id])

  memberCount   Int @default(0)
  activeMembers Int @default(0)

  totalDistanceKm Float @default(0)
  avgDistanceKm   Float @default(0)

  activeScore   Float @default(0)
  distanceScore Float @default(0)
  finalScore    Float @default(0)

  result ClubWarResult?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([warId, clanId])
  @@index([clanId])
}

model ClanEvent {
  id          String @id @default(uuid())
  clanId      String
  createdById String

  title       String
  description String?
  location    String?

  startsAt DateTime
  endsAt   DateTime

  maxParticipants Int?
  status          ClanEventStatus @default(UPCOMING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clan      Clan @relation(fields: [clanId], references: [id], onDelete: Cascade)
  createdBy User @relation("CreatedClanEvents", fields: [createdById], references: [id], onDelete: Cascade)

  participants ClanEventParticipant[]

  @@index([clanId])
  @@index([createdById])
  @@index([startsAt])
  @@index([status])
  @@map("clan_events")
}

model ClanEventParticipant {
  id      String @id @default(uuid())
  eventId String
  userId  String

  joinedAt DateTime @default(now())

  event ClanEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@map("clan_event_participants")
}

enum ClanEventStatus {
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ClubWarType {
  AUTOMATIC
  MANUAL
}

enum ClubWarStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
  DECLINED
}

enum ClubWarResult {
  WIN
  LOSE
  DRAW
}

enum ActivityMode {
  WALK
  RUN
  CYCLE
  DRIVE
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ClanRole {
  LEADER
  RUNNER
  CAPTAIN
}

enum ClanJoinRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ClanInviteStatus {
  PENDING
  ACCEPTED
  REJECTED
}
